<mujoco model="myscene">
    <option gravity="0 0 -9.81" timestep="0.002" />

    <worldbody>
        <geom name="floor" type="plane" size="2 2 1" rgba="1 1 1 1" />

        <camera
            name="cam"
            pos="1.8 -1.8 1.2"
            xyaxes="0.707 0.707 0 -0.3 0.3 0.9"
        />

        <body name="link1" pos="0 0 2">
            <joint name="j1" type="hinge" axis="0 1 0" damping="0.2" />
            <geom
                type="capsule"
                rgba="1 0 0 1"
                fromto="0 0 0 0.5 0 0"
                size="0.03"
                mass="1"
            />

            <body name="link2" pos="0.5 0 0">
                <joint name="j2" type="hinge" axis="0 1 0" damping="0.2" />
                <geom
                    type="capsule"
                    fromto="0 0 0 0.5 0 0"
                    rgba="0 1 0 1"
                    size="0.03"
                    mass="1"
                />
            </body>
        </body>

    </worldbody>

    <actuator>
        <motor name="j1_motor" joint="j1" />
    </actuator>
</mujoco>
